{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-XSS-Protection",           "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sales-manager",                "destination": "/sales-manager/index.html" },
    { "source": "/sales-manager/weekly-review",  "destination": "/sales-manager/weekly-review/index.html" },
    { "source": "/sales-manager/1on1-agenda",    "destination": "/sales-manager/1on1-agenda/index.html" }
  ]
}
